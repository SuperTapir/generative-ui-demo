{
  "name": "generative-ui-monorepo",
  "private": true,
  "version": "0.3.0",
  "description": "Generative UI monorepo — JS SDK, Python SDK, and demo app",
  "scripts": {
    "build": "pnpm --filter generative-ui build",
    "build:js": "pnpm --filter generative-ui build",
    "dev:frontend": "pnpm --filter generative-ui-demo-frontend dev",
    "dev:backend": "cd demo/backend && uvicorn main:app --reload --port 8000",
    "dev": "echo 'Run dev:backend and dev:frontend in separate terminals'"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "dompurify": "^3.3.3",
    "marked": "^17.0.4",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "morphdom": "^2.7.8"
  }
}
