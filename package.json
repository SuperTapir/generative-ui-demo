{
  "name": "generative-ui",
  "version": "0.1.0",
  "description": "Platform-agnostic generative UI library for LLMs - render interactive HTML widgets from any AI model",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./renderer": {
      "import": "./dist/renderer.js",
      "types": "./dist/renderer.d.ts"
    },
    "./adapters/openai": {
      "import": "./dist/adapters/openai.js",
      "types": "./dist/adapters/openai.d.ts"
    },
    "./adapters/anthropic": {
      "import": "./dist/adapters/anthropic.js",
      "types": "./dist/adapters/anthropic.d.ts"
    }
  },
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "generative-ui",
    "llm",
    "ai",
    "widget",
    "streaming",
    "openai",
    "anthropic",
    "function-calling"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "marked": "^17.0.4",
    "morphdom": "^2.7.8"
  }
}
